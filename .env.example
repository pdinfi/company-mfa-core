# =============================================================================
# django-mfa-core — example .env for the PROJECT that installs this package
# =============================================================================
# This library never reads .env itself. You copy this file to YOUR Django app,
# load it (python-dotenv, django-environ, etc.), and assign values in YOUR
# settings.py to Django settings and MFA_SETTINGS.
#
# Where MFA data comes from (by design):
#
#   Authenticator (TOTP)
#     • Secret: generated at enrollment, stored as MFADevice.secret_ciphertext
#       (encrypted); codes verified with pyotp. Not in .env.
#     • User account name in the otpauth URI: from the user row (e.g. username).
#     • Issuer / authenticator presets (Google, Microsoft, AWS VMFA, etc.):
#       YOU define in MFA_SETTINGS, typically using the variables below from
#       this .env.
#
#   Email OTP
#     • To: user.email on the user model (your database).
#     • From + how mail is sent: YOUR Django email settings, usually filled
#       from this .env (SMTP or API backend).
#     • Optional MFA_SETTINGS["EMAIL_FROM"] — can mirror MFA_EMAIL_FROM here.
#
#   SMS OTP
#     • To: user.phone or user.phone_number on the user model (your database).
#     • The default package provider only logs; real SMS needs YOUR subclass
#       and YOUR gateway credentials from this .env (Twilio, Vonage, SNS, …).
# =============================================================================

# --- Django (required) ---
SECRET_KEY=change-me-to-a-long-random-string

# --- MFA encryption (strongly recommended in production) ---
# TOTP secrets at rest are encrypted with this Fernet key (not the raw secret).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# settings.py: MFA_ENCRYPTION_KEY = os.environ.get("MFA_ENCRYPTION_KEY")
MFA_ENCRYPTION_KEY=

# =============================================================================
# Authenticator (TOTP) — config from YOUR .env; user-specific data from DB + API
# =============================================================================
# Issuer name shown in the authenticator app (same TOTP algorithm for Google,
# Microsoft, AWS Virtual MFA, etc.). Wire into MFA_SETTINGS in settings.py, e.g.:
#   MFA_SETTINGS = {
#       "TOTP_DEFAULT_ISSUER": os.environ.get("MFA_TOTP_ISSUER", "My Company"),
#       # or build "TOTP_APPS" with multiple ids/labels using this issuer, see README
#   }
MFA_TOTP_ISSUER=My Company

# =============================================================================
# Email OTP — delivery config from YOUR .env; recipient from user.email
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@example.com
# Maps to MFA_SETTINGS["EMAIL_FROM"] if you set it in settings.py:
MFA_EMAIL_FROM=security@example.com

# =============================================================================
# SMS OTP — gateway creds from YOUR .env; recipient from user.phone / phone_number
# =============================================================================
# The package ships a stub SMS provider; you subclass SMSMFAProvider and read
# whichever vendor you use. Examples (uncomment the block that matches your app):
#
# --- Plivo (https://www.plivo.com) ---
# PLIVO_AUTH_ID=
# PLIVO_AUTH_TOKEN=
# PLIVO_SRC_NUMBER=
#
# --- Twilio ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
#
# --- Any other vendor (Vonage, AWS SNS, MessageBird, etc.) ---
# Define names you need and read them in your provider subclass — not limited to the above.

# =============================================================================
# Other optional infrastructure (from YOUR .env)
# =============================================================================
# Rate limiting backend "redis":
REDIS_URL=redis://localhost:6379/0

# Celery when MFA_SETTINGS["CELERY_OTP"] is True:
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
