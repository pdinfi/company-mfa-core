# =============================================================================
# django-mfa-core — example environment variables
# =============================================================================
# This library does NOT load .env files. Copy to .env in your Django project,
# load with python-dotenv / django-environ (or similar), and wire values in
# settings.py as shown in the README.
# =============================================================================

# --- Django (required) ---
# Used for sessions, signing, and (if MFA_ENCRYPTION_KEY is unset) deriving the
# Fernet key for TOTP secrets; also used when hashing backup codes.
SECRET_KEY=change-me-to-a-long-random-string

# --- MFA encryption (strongly recommended in production) ---
# Fernet key: 32 url-safe base64-encoded bytes.
# Generate once:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In settings:     MFA_ENCRYPTION_KEY = os.environ["MFA_ENCRYPTION_KEY"]
MFA_ENCRYPTION_KEY=

# --- Rate limiting (optional) ---
# Only if MFA_SETTINGS["RATE_LIMIT_BACKEND"] = "redis"
# In settings:     MFA_SETTINGS = { ..., "REDIS_URL": os.environ.get("REDIS_URL") }
REDIS_URL=redis://localhost:6379/0

# --- Email OTP (optional; Django sends mail via send_mail) ---
# Configure your EMAIL_BACKEND and, for SMTP, the usual Django variables:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
# Used as From: if MFA_SETTINGS["EMAIL_FROM"] is not set
DEFAULT_FROM_EMAIL=noreply@example.com
# Optional: map in settings to MFA_SETTINGS["EMAIL_FROM"]
MFA_EMAIL_FROM=security@example.com

# --- Celery (optional) ---
# Only if you use Celery for async OTP delivery (MFA_SETTINGS["CELERY_OTP"] = True)
# and have broker/result URLs in the environment.
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- SMS (not used by the default stub provider) ---
# The built-in SMS provider logs only. If you subclass it for Twilio, Vonage,
# etc., define your own variables and read them in your provider code, e.g.:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
